{
    "name": "yacoubalhaidari/laravel-apple-google-wallet-integration",
    "description": "Laravel package for Apple Wallet (.pkpass) and Google Wallet loyalty stamp cards",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "apple-wallet",
        "google-wallet",
        "pkpass",
        "loyalty",
        "stamp-card"
    ],
    "authors": [
        {
            "name": "Yacoub Alhaidari",
            "email": "yacoub@yacoubalhaidari.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-openssl": "*",
        "ext-zip": "*",
        "firebase/php-jwt": "^7.0",
        "google/apiclient": "^2.15",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Yacoubalhaidari\\AppleGoogleWallet\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Yacoubalhaidari\\AppleGoogleWallet\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yacoubalhaidari\\AppleGoogleWallet\\AppleGoogleWalletServiceProvider"
            ],
            "aliases": {
                "AppleWallet": "Yacoubalhaidari\\AppleGoogleWallet\\Facades\\AppleWallet",
                "GoogleWallet": "Yacoubalhaidari\\AppleGoogleWallet\\Facades\\GoogleWallet"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
